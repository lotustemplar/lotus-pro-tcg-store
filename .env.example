# --- Database ---
# Local dev (SQLite, zero setup):
DATABASE_URL="file:./dev.db"
# Production (Postgres, Neon recommended):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Stripe ---
# Get these from https://dashboard.stripe.com/test/apikeys (use test keys until launch)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- tawk.to live chat ---
# Find these under your tawk.to widget code or direct chat link.
NEXT_PUBLIC_TAWKTO_PROPERTY_ID=""
NEXT_PUBLIC_TAWKTO_WIDGET_ID=""

# --- Admin login ---
# Single-admin gate for /admin. Change these before deploying.
ADMIN_EMAIL="admin@lotusprotcg.com"
ADMIN_PASSWORD="change-me-now"

# Signs the admin session cookie — set to a long random string in production
ADMIN_SESSION_SECRET="dev-only-insecure-secret-change-me"
